# ── Python ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# ── Virtual environment (machine-specific, large) ─────────
.venv/
venv/

# ── Secrets / credentials (NEVER commit) ──────────────────
.env
*.key
*.pem
credentials.json
.netrc

# ── Data (too big for git; rebuilt from config) ───────────
data/
*.tif
*.tiff
*.nc
*.zarr/
*.h5
*.hdf

# ── Demo artifacts (small and precomputed, so deliberately committed) ──
# The hosted app reads these; without them there is nothing to deploy.
!docs/app_data/*.nc

# ── Model weights / checkpoints / run artifacts ───────────
*.pt
*.pth
*.ckpt
*.onnx
checkpoints/
artifacts/
logs/
*.log

# ── Working notes kept locally, not part of the project ───
Ecosystem State Forecaster.md
humaniser.md

# ── OS / editor cruft ─────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
